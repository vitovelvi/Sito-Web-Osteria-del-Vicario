  .grow-caption {
    position: absolute;
    bottom: 4rem;
    left: 0;
    right: 0;
    text-align: center;
    color: var(--avorio);
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.4rem);
    opacity: 0;
    z-index: 5;
  }
