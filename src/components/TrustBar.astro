---
const badges = [
  { label: "400+ recensioni", note: "Booking.com" },
  { label: "300+ recensioni", note: "TripAdvisor" },
  { label: "Dal 1100", note: "Monastero storico" },
  { label: "100% vegetale", note: "Cucina di stagione" },
];
---

<section class="trust-bar" aria-label="Punti di forza">
  {badges.map((badge) => (
    <div class="trust-item">
      <strong>{badge.label}</strong>
      <span>{badge.note}</span>
    </div>
  ))}
</section>

<style>
  .trust-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: 2.5rem clamp(1.5rem, 6vw, 6rem);
    background: var(--notte);
    border-bottom: 1px solid rgba(242, 233, 215, 0.08);
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.2rem;
  }

  .trust-item strong {
    font-family: var(--font-display);
    color: var(--oro-sera);
    font-size: 1.1rem;
  }

  .trust-item span {
    color: var(--avorio);
    opacity: 0.65;
    font-size: 0.8rem;
  }
</style>
