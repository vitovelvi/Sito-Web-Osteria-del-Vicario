---
const steps = [
  { n: "01", title: "Scegli data e orario", desc: "Scrivici il giorno che preferisci per la cena o per il soggiorno." },
  { n: "02", title: "Invia la richiesta", desc: "Compila il modulo: la prenotazione parte direttamente dalla tua email." },
  { n: "03", title: "Ti confermiamo", desc: "Ti rispondiamo per confermare disponibilità e dettagli entro breve." },
];
---

<section class="come-funziona" id="come-funziona">
  <p class="eyebrow">Come funziona</p>
  <h2>Prenotare è semplice</h2>
  <div class="steps-grid">
    {steps.map((s) => (
      <div class="step-card">
        <span class="step-n">{s.n}</span>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .come-funziona {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 6rem);
    text-align: center;
  }

  .come-funziona h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--avorio);
    margin: 0.6rem 0 3rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .step-card {
    text-align: left;
    padding: 1.5rem;
    border-left: 1px solid rgba(232, 177, 90, 0.25);
  }

  .step-n {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--cotto);
    display: block;
    margin-bottom: 0.5rem;
  }

  .step-card h3 {
    color: var(--avorio);
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  .step-card p {
    color: var(--avorio);
    opacity: 0.8;
    line-height: 1.6;
    font-size: 0.92rem;
  }

  @media (max-width: 760px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
