---
const servizi = [
  {
    icon: "🍽️",
    title: "Cena à la carte",
    desc: "Menu stagionale 100% vegetale, piatti che cambiano con l'orto e con le stagioni.",
  },
  {
    icon: "🥂",
    title: "Eventi privati",
    desc: "Cene e ricorrenze nella sala del monastero, su richiesta e fino a esaurimento posti.",
  },
  {
    icon: "🛏️",
    title: "Pernottamento",
    desc: "Camere ricavate negli ambienti storici, a pochi passi dalla sala da pranzo.",
  },
  {
    icon: "☀️",
    title: "Colazione",
    desc: "Colazione dolce e salata con prodotti locali, servita per chi soggiorna in camera.",
  },
];
---

<section class="servizi" id="servizi">
  <p class="eyebrow">Cosa offriamo</p>
  <h2>Un'unica esperienza, due modi di viverla</h2>
  <div class="servizi-grid">
    {servizi.map((s) => (
      <div class="servizio-card tilt-card glass">
        <span class="servizio-icon" aria-hidden="true">{s.icon}</span>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .servizi {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 6rem);
    text-align: center;
  }

  .servizi h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--avorio);
    margin: 0.6rem 0 3rem;
  }

  .servizi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .servizio-card {
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    text-align: left;
  }

  .servizio-icon {
    font-size: 1.8rem;
    display: block;
    margin-bottom: 1rem;
  }

  .servizio-card h3 {
    color: var(--oro-sera);
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 0 0 0.6rem;
  }

  .servizio-card p {
    color: var(--avorio);
    opacity: 0.8;
    line-height: 1.6;
    font-size: 0.92rem;
  }

  @media (max-width: 900px) {
    .servizi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .servizi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
