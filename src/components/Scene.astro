---
interface Props {
  image: string;
  alt: string;
  eyebrow: string;
  title: string;
  text: string;
  tone?: "dark" | "light";
  cta?: { label: string; href: string };
}

const { image, alt, eyebrow, title, text, tone = "dark", cta } = Astro.props;
---

<section class="scene" data-tone={tone}>
  <div class="scene-img" style={`background-image: url('${image}')`} role="img" aria-label={alt}></div>
  <div class="scene-overlay"></div>
  <div class="scene-caption">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    <p class="scene-text">{text}</p>
    {cta && (
      <a class="btn btn-cotto" href={cta.href}>{cta.label}</a>
    )}
  </div>
</section>

<style>
  .scene {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .scene-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: var(--notte);
    will-change: transform;
  }

  .scene-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(33, 23, 16, 0.1) 0%,
      rgba(33, 23, 16, 0.55) 70%,
      rgba(33, 23, 16, 0.85) 100%
    );
  }

  .scene-caption {
    position: relative;
    z-index: 2;
    padding: 4rem clamp(1.5rem, 6vw, 6rem);
    max-width: 640px;
    opacity: 0;
  }

  .scene-caption h2 {
    font-size: clamp(2rem, 5vw, 3.4rem);
    color: var(--avorio);
    margin: 0.4rem 0 1rem;
  }

  .scene-text {
    color: var(--avorio);
    opacity: 0.85;
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    margin-bottom: 1.5rem;
  }
</style>
