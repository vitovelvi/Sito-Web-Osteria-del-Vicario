---
const piattaforme = [
  {
    nome: "Booking.com",
    nota: "400+ recensioni",
    href: "https://www.booking.com/hotel/it/osteria-del-vicario.it.html",
  },
  {
    nome: "TripAdvisor",
    nota: "300+ recensioni",
    href: "https://mytreats.app/food_identity/curation/osteria_del_vicario/",
  },
];
---

<section class="recensioni" id="recensioni">
  <div class="recensioni-inner">
    <p class="eyebrow eyebrow-light">Recensioni</p>
    <h2>Travellers' Choice.</h2>

    <div class="rec-stats">
      <div class="rec-stat-item">
        <div class="rec-stat" data-count="4.8" data-decimals="1">0</div>
        <div class="rec-stat-label">/5 — voto medio</div>
      </div>
      <div class="rec-stat-item">
        <div class="rec-stat" data-count="700" data-decimals="0">0</div>
        <div class="rec-stat-label">recensioni verificate</div>
      </div>
      <div class="rec-stat-item">
        <div class="rec-stat" data-count="900" data-decimals="0">0</div>
        <div class="rec-stat-label">anni di storia del monastero</div>
      </div>
    </div>

    <div class="rec-quotes">
      <p class="rec-quote">"Un luogo che non ti aspetti: pietra del 1100 e una cucina vegetale sorprendente. La terrazza al tramonto vale il viaggio." <cite>— TripAdvisor</cite></p>
      <p class="rec-quote">"Abbiamo dormito in una vera cella di monastero e mangiato uno dei migliori menu degustazione vegetali in Toscana." <cite>— Google Recensioni</cite></p>
    </div>

    <div class="rec-grid">
      {piattaforme.map((p) => (
        <a class="rec-card" href={p.href} target="_blank" rel="noopener">
          <span class="rec-stars" aria-hidden="true">★★★★★</span>
          <strong>{p.nome}</strong>
          <span class="rec-count">{p.nota}</span>
          <span class="rec-link">Leggi le recensioni →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .recensioni {
    background: var(--notte);
    color: var(--avorio);
  }

  .recensioni-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem clamp(1.5rem, 6vw, 6rem);
  }

  .eyebrow-light {
    color: var(--candela);
  }

  .recensioni h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--avorio);
    margin: 0.6rem 0 2rem;
  }

  .rec-stats {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .rec-stat {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4rem);
    color: var(--candela);
    line-height: 1;
  }

  .rec-stat-label {
    font-size: 0.85rem;
    opacity: 0.65;
    letter-spacing: 0.05em;
    margin-top: 0.3rem;
  }

  .rec-quotes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 760px) {
    .rec-quotes {
      grid-template-columns: 1fr;
    }
  }

  .rec-quote {
    border-left: 2px solid var(--candela);
    padding-left: 1.4rem;
    font-size: 1rem;
    opacity: 0.88;
    line-height: 1.7;
  }

  .rec-quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.8rem;
    opacity: 0.6;
    font-style: normal;
  }

  .rec-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .rec-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 2.2rem 1.5rem;
    border-radius: 1rem;
    text-decoration: none;
    background: rgba(242, 233, 215, 0.06);
    border: 1px solid rgba(242, 233, 215, 0.12);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .rec-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(33, 23, 16, 0.1);
  }

  .rec-stars {
    color: var(--candela);
    letter-spacing: 0.15em;
    font-size: 1rem;
  }

  .rec-card strong {
    color: var(--candela);
    font-family: var(--font-display);
    font-size: 1.2rem;
  }

  .rec-count {
    color: var(--avorio);
    opacity: 0.6;
    font-size: 0.9rem;
  }

  .rec-link {
    margin-top: 0.6rem;
    color: var(--cotto);
    font-size: 0.82rem;
    font-weight: 600;
  }

  @media (max-width: 560px) {
    .rec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
