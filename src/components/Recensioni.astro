---
const piattaforme = [
  {
    nome: "Booking.com",
    nota: "400+ recensioni",
    href: "https://www.booking.com/hotel/it/osteria-del-vicario.it.html",
  },
  {
    nome: "TripAdvisor",
    nota: "300+ recensioni",
    href: "https://mytreats.app/food_identity/curation/osteria_del_vicario/",
  },
];
---

<section class="recensioni" id="recensioni">
  <div class="recensioni-inner reveal">
    <p class="eyebrow eyebrow-light">Cosa dicono di noi</p>
    <h2>Le voci di chi è già stato qui</h2>
    <p class="placeholder-note">
      Le recensioni vere arrivano da Booking.com e TripAdvisor: leggile direttamente sulle
      piattaforme ufficiali.
    </p>
    <div class="rec-grid">
      {piattaforme.map((p) => (
        <a class="rec-card" href={p.href} target="_blank" rel="noopener">
          <span class="rec-stars" aria-hidden="true">★★★★★</span>
          <strong>{p.nome}</strong>
          <span class="rec-count">{p.nota}</span>
          <span class="rec-link">Leggi le recensioni →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .recensioni {
    background: var(--avorio);
  }

  .recensioni-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 6rem);
    text-align: center;
  }

  .eyebrow-light {
    color: var(--cotto);
  }

  .recensioni h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--notte);
    margin: 0.6rem 0 0.8rem;
  }

  .placeholder-note {
    color: var(--notte);
    opacity: 0.6;
    font-size: 0.85rem;
    margin-bottom: 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .rec-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .rec-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 2.2rem 1.5rem;
    border-radius: 1rem;
    text-decoration: none;
    background: #fff;
    border: 1px solid rgba(33, 23, 16, 0.08);
    box-shadow: 0 12px 30px rgba(33, 23, 16, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .rec-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(33, 23, 16, 0.1);
  }

  .rec-stars {
    color: var(--candela);
    letter-spacing: 0.15em;
    font-size: 1rem;
  }

  .rec-card strong {
    color: var(--cotto);
    font-family: var(--font-display);
    font-size: 1.2rem;
  }

  .rec-count {
    color: var(--notte);
    opacity: 0.6;
    font-size: 0.9rem;
  }

  .rec-link {
    margin-top: 0.6rem;
    color: var(--cotto);
    font-size: 0.82rem;
    font-weight: 600;
  }

  @media (max-width: 560px) {
    .rec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
