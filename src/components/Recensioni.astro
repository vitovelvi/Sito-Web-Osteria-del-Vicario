---
const piattaforme = [
  {
    nome: "Booking.com",
    nota: "400+ recensioni",
    href: "https://www.booking.com/hotel/it/osteria-del-vicario.it.html",
  },
  {
    nome: "TripAdvisor",
    nota: "300+ recensioni",
    href: "https://mytreats.app/food_identity/curation/osteria_del_vicario/",
  },
];
---

<section class="recensioni" id="recensioni">
  <p class="eyebrow">Cosa dicono di noi</p>
  <h2>Le voci di chi è già stato qui</h2>
  <p class="placeholder-note">
    Le recensioni vere arrivano da Booking.com e TripAdvisor: leggile direttamente sulle
    piattaforme ufficiali.
  </p>
  <div class="rec-grid">
    {piattaforme.map((p) => (
      <a class="rec-card glass" href={p.href} target="_blank" rel="noopener">
        <strong>{p.nome}</strong>
        <span>{p.nota}</span>
        <span class="rec-link">Leggi le recensioni →</span>
      </a>
    ))}
  </div>
</section>

<style>
  .recensioni {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 6rem);
    text-align: center;
  }

  .recensioni h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--avorio);
    margin: 0.6rem 0 0.8rem;
  }

  .placeholder-note {
    color: var(--avorio);
    opacity: 0.65;
    font-size: 0.85rem;
    margin-bottom: 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .rec-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .rec-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .rec-card:hover {
    transform: translateY(-3px);
  }

  .rec-card strong {
    color: var(--oro-sera);
    font-family: var(--font-display);
    font-size: 1.15rem;
  }

  .rec-card span {
    color: var(--avorio);
    opacity: 0.8;
    font-size: 0.9rem;
  }

  .rec-link {
    margin-top: 0.6rem;
    color: var(--candela);
    font-size: 0.82rem;
  }

  @media (max-width: 560px) {
    .rec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
