---
interface Props {
  type: "tavolo" | "camera";
  email: string;
  phone: string;
}

const { type, email, phone } = Astro.props;
const isTavolo = type === "tavolo";
---

<div class="booking">
  <form class="booking-form" data-type={type} data-email={email}>
    <div class="field-row">
      <label>
        Nome e cognome
        <input type="text" name="nome" required />
      </label>
      <label>
        Telefono
        <input type="tel" name="telefono" required />
      </label>
    </div>
    <div class="field-row">
      <label>
        Data
        <input type="date" name="data" required />
      </label>
      <label>
        {isTavolo ? "Persone" : "Notti"}
        <input type="number" name="quantita" min="1" required />
      </label>
    </div>
    <label class="field-full">
      Note
      <textarea name="note" rows="3" placeholder={isTavolo ? "Allergie, intolleranze, occasioni speciali..." : "Richieste particolari..."}></textarea>
    </label>
    <button type="submit" class="btn btn-cotto">
      {isTavolo ? "Invia richiesta tavolo" : "Invia richiesta camera"}
    </button>
  </form>

  <div class="booking-direct">
    <p>Preferisci parlare con noi?</p>
    <a class="btn btn-outline" href={`tel:${phone}`}>Chiama {phone}</a>
    <a class="btn btn-outline" href={`mailto:${email}`}>Scrivi una email</a>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLFormElement>(".booking-form").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const type = form.dataset.type;
      const email = form.dataset.email;
      const subject =
        type === "tavolo" ? "Richiesta prenotazione tavolo" : "Richiesta prenotazione camera";
      const body = [
        `Nome: ${data.get("nome")}`,
        `Telefono: ${data.get("telefono")}`,
        `Data: ${data.get("data")}`,
        `${type === "tavolo" ? "Persone" : "Notti"}: ${data.get("quantita")}`,
        `Note: ${data.get("note") || "-"}`,
      ].join("\n");
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(
        subject
      )}&body=${encodeURIComponent(body)}`;
    });
  });
</script>

<style>
  .booking {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: linear-gradient(
      135deg,
      rgba(242, 233, 215, 0.1),
      rgba(242, 233, 215, 0.03)
    );
    border: 1px solid rgba(242, 233, 215, 0.16);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
  }

  .booking-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--avorio);
    opacity: 0.85;
  }

  input,
  textarea {
    font-family: var(--font-body);
    background: rgba(242, 233, 215, 0.08);
    border: 1px solid rgba(242, 233, 215, 0.25);
    border-radius: 0.4rem;
    padding: 0.65rem 0.8rem;
    color: var(--avorio);
    font-size: 1rem;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--oro-sera);
  }

  .booking-form button {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .booking-direct {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.85rem;
    border-left: 1px solid rgba(242, 233, 215, 0.15);
    padding-left: 2rem;
  }

  .booking-direct p {
    color: var(--avorio);
    opacity: 0.8;
    margin: 0 0 0.25rem;
  }

  @media (max-width: 760px) {
    .booking {
      grid-template-columns: 1fr;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
    .booking-direct {
      border-left: none;
      border-top: 1px solid rgba(242, 233, 215, 0.15);
      padding-left: 0;
      padding-top: 1.5rem;
    }
  }
</style>
