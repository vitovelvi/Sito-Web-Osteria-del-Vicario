---
const punti = [
  { title: "Storia autentica", desc: "Le pietre di un monastero del XII secolo, non una scenografia." },
  { title: "Solo cucina vegetale", desc: "Nessun compromesso: verdure, legumi ed erbe del territorio, lavorati con tecnica." },
  { title: "Dormi dove ceni", desc: "Le camere sono a pochi passi dal tavolo, dentro lo stesso edificio storico." },
  { title: "Certaldo Alto", desc: "Un borgo medievale fuori dalle rotte più battute, tra Firenze e Siena." },
];
---

<section class="perche-noi" id="perche-noi">
  <p class="eyebrow">Perché scegliere noi</p>
  <h2>Quattro motivi per fermarsi qui</h2>
  <ul class="punti-list">
    {punti.map((p) => (
      <li>
        <h3>{p.title}</h3>
        <p>{p.desc}</p>
      </li>
    ))}
  </ul>
</section>

<style>
  .perche-noi {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem clamp(1.5rem, 6vw, 6rem);
    text-align: center;
  }

  .perche-noi h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--avorio);
    margin: 0.6rem 0 3rem;
  }

  .punti-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: left;
  }

  .punti-list h3 {
    color: var(--oro-sera);
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }

  .punti-list p {
    color: var(--avorio);
    opacity: 0.8;
    line-height: 1.6;
    font-size: 0.9rem;
    margin: 0;
  }

  @media (max-width: 900px) {
    .punti-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .punti-list {
      grid-template-columns: 1fr;
    }
  }
</style>
