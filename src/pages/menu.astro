---
import Layout from "../layouts/Layout.astro";
import NavFunnel from "../components/NavFunnel.astro";
import PageHeader from "../components/PageHeader.astro";
import Footer from "../components/Footer.astro";
import { piatti, risottoDelMese, dolci } from "../data/piatti.js";
---

<Layout
  title="Menu — Osteria del Vicario"
  description="Menu à la carte dell'Osteria del Vicario, Certaldo Alto: piatti, ingredienti e allergeni."
>
  <NavFunnel />

  <PageHeader
    image="/immagini/piatti/risotto-pesto.jpg"
    eyebrow="Menu à la carte"
    title="Il nostro menu"
    text="Ad ogni commensale è richiesto di selezionare un minimo di 2 portate. Apri ogni piatto per scoprire storia, ingredienti e abbinamento."
  />

  <main>
    <section class="pricing reveal">
      <div class="pricing-card">
        <span class="pricing-n">2</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 40</span>
      </div>
      <div class="pricing-card">
        <span class="pricing-n">3</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 50</span>
      </div>
      <div class="pricing-card">
        <span class="pricing-n">4</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 65</span>
      </div>
    </section>

    <p class="placeholder-note">
      * Allergeni indicativi in attesa di conferma definitiva dalla cucina. Per allergie e
      intolleranze specifiche, segnalacelo al momento della prenotazione.
    </p>

    <section class="menu-sezione reveal">
      <div class="piatti-grid">
        {piatti.map((p) => (
          <a class="piatto-card tilt-card glass" href={`/piatti/${p.slug}`}>
            <div class="piatto-img">
              <img src={p.img} alt={p.nome} loading="lazy" width="400" height="300" />
            </div>
            <div class="piatto-body">
              <h3>{p.nome}</h3>
              <p class="nome-en">{p.nomeEn}</p>
              <span class="piatto-link">Scopri il piatto →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="menu-sezione reveal">
      <h2>{risottoDelMese.nome}</h2>
      <p class="sezione-sub">{risottoDelMese.nomeEn}</p>
      <div class="variant-gallery">
        {risottoDelMese.varianti.map((v) => (
          <div class="variant-item tilt-card">
            <img src={v.img} alt={v.alt} loading="lazy" width="300" height="220" />
          </div>
        ))}
      </div>
      <div class="piatto-meta risotto-meta">
        <div class="meta-block">
          <span class="meta-label">Ingredienti</span>
          <p>{risottoDelMese.ingredienti.join(", ")}</p>
        </div>
        <div class="meta-block">
          <span class="meta-label">Allergeni</span>
          <p>{risottoDelMese.allergeni.join(", ")}</p>
        </div>
      </div>
    </section>

    <section class="menu-sezione reveal">
      <h2>{dolci.nome}</h2>
      <p class="sezione-sub">{dolci.nomeEn}</p>
      <p class="dolci-testo">{dolci.testo}</p>
      <div class="variant-gallery">
        {dolci.foto.map((d) => (
          <div class="variant-item tilt-card">
            <img src={d.img} alt={d.alt} loading="lazy" width="300" height="220" />
          </div>
        ))}
      </div>
    </section>

    <div class="menu-cta">
      <a class="btn btn-cotto" href="/tavolo">Prenota un tavolo</a>
    </div>
  </main>

  <Footer />

  <script>
    import { initTilt, initPageHeader, initReveal } from "../scripts/scroll.js";
    initPageHeader();
    initReveal();
    initTilt();
  </script>
</Layout>

<style>
  main {
    background: var(--notte);
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem clamp(1.5rem, 6vw, 6rem) 6rem;
  }

  .pricing {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 1.2rem 1.8rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(232, 177, 90, 0.25);
    background: rgba(242, 233, 215, 0.04);
  }

  .pricing-n {
    font-family: var(--font-display);
    color: var(--oro-sera);
    font-size: 1.6rem;
  }

  .pricing-label {
    color: var(--avorio);
    opacity: 0.7;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-price {
    color: var(--candela);
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-top: 0.3rem;
  }

  .placeholder-note {
    color: var(--ardesia);
    font-size: 0.8rem;
    margin-bottom: 3rem;
    max-width: 700px;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .menu-sezione {
    margin-bottom: 4rem;
  }

  .menu-sezione h2 {
    font-family: var(--font-display);
    color: var(--oro-sera);
    font-size: 1.4rem;
    margin: 0 0 0.3rem;
    text-align: center;
  }

  .sezione-sub {
    color: var(--avorio);
    opacity: 0.6;
    font-style: italic;
    font-size: 0.9rem;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .dolci-testo {
    color: var(--avorio);
    opacity: 0.8;
    text-align: center;
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .piatti-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .piatto-card {
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    overflow: hidden;
  }

  .piatto-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .piatto-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .piatto-card:hover .piatto-img img {
    transform: scale(1.06);
  }

  .piatto-body {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .piatto-body h3 {
    color: var(--avorio);
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin: 0;
  }

  .nome-en {
    color: var(--avorio);
    opacity: 0.55;
    font-style: italic;
    font-size: 0.85rem;
    margin: 0;
  }

  .piatto-link {
    color: var(--candela);
    font-size: 0.82rem;
    margin-top: 0.4rem;
  }

  .piatto-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid rgba(242, 233, 215, 0.1);
    padding-top: 0.8rem;
    margin-top: 0.4rem;
  }

  .risotto-meta {
    max-width: 600px;
    margin: 1.5rem auto 0;
  }

  .meta-label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
    color: var(--oliva);
    margin-bottom: 0.2rem;
  }

  .meta-block p {
    color: var(--avorio);
    opacity: 0.75;
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.5;
  }

  .variant-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .variant-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 0.6rem;
    border: 1px solid rgba(242, 233, 215, 0.08);
  }

  .variant-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .menu-cta {
    text-align: center;
    margin-top: 1rem;
  }

  @media (max-width: 760px) {
    .piatti-grid {
      grid-template-columns: 1fr;
    }
    .variant-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
