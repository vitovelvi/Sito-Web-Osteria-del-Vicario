---
import Layout from "../layouts/Layout.astro";
import NavFunnel from "../components/NavFunnel.astro";
import PageHeader from "../components/PageHeader.astro";
import Footer from "../components/Footer.astro";

const piatti = [
  {
    nome: "Macedonia frutta e verdure di stagione",
    nomeEn: "Seasonal vegetable and fruit salad",
    img: "/immagini/piatti/piatto-12.jpg",
    ingredienti: ["Verdure di stagione", "Frutta di stagione", "Erbe aromatiche"],
    allergeni: [],
  },
  {
    nome: "Zucchina, cetriolo, mandorla e capperi",
    nomeEn: "Courgette, cucumber, almond and capers",
    img: "/immagini/piatti/vegan.jpg",
    ingredienti: ["Zucchina", "Cetriolo", "Mandorla", "Capperi"],
    allergeni: ["Frutta a guscio (mandorla)"],
  },
  {
    nome: "Essenziale di panzanella",
    nomeEn: "Tomato, cucumber, onion, bread",
    img: "/immagini/piatti/piatto-13.jpeg",
    ingredienti: ["Pomodoro", "Cetriolo", "Cipolla", "Pane toscano"],
    allergeni: ["Glutine"],
  },
  {
    nome: "Taco Toscano",
    nomeEn: "Taco, white beans, pappa al pomodoro and onions",
    img: "/immagini/piatti/piatto-03.jpeg",
    ingredienti: ["Taco", "Fagioli bianchi", "Pappa al pomodoro", "Cipolle"],
    allergeni: ["Glutine"],
  },
  {
    nome: "Spaghetti, spirulina, nori e salicornia",
    nomeEn: "Spaghetti, spirulina and salicornia seaweed",
    img: "/immagini/piatti/piatto-20.jpeg",
    ingredienti: ["Spaghetti", "Spirulina", "Alga nori", "Salicornia"],
    allergeni: ["Glutine"],
  },
  {
    nome: "Pasta fresca fatta a mano del mese",
    nomeEn: "Homemade handmade pasta",
    img: "/immagini/piatti/piatto-10.jpeg",
    ingredienti: ["Pasta fresca fatta a mano", "Ricetta e condimento del mese"],
    allergeni: ["Glutine", "Può contenere uova"],
  },
  {
    nome: "Anguria BBQ, purè di patate, cipolle",
    nomeEn: "BBQ watermelon, potato puree, onions",
    img: "/immagini/piatti/piatto-04.jpeg",
    ingredienti: ["Anguria grigliata", "Purè di patate", "Cipolle caramellate"],
    allergeni: [],
  },
  {
    nome: "Melanzana, hummus, uvetta e basilico",
    nomeEn: "Roasted eggplant, hummus, raisins and basil",
    img: "/immagini/piatti/piatto-01.jpeg",
    ingredienti: ["Melanzana arrostita", "Hummus di ceci", "Uvetta", "Basilico"],
    allergeni: ["Sesamo (tahin)"],
  },
];

const risottoDelMese = {
  nome: "Risotto del mese",
  nomeEn: "Risotto of the month",
  ingredienti: ["Riso carnaroli", "Ricetta a rotazione mensile in base alla stagione"],
  allergeni: ["Può contenere lattosio, a seconda della ricetta del mese"],
  varianti: [
    { img: "/immagini/piatti/risotto-pesto.jpg", alt: "Risotto al pesto" },
    { img: "/immagini/piatti/piatto-risotto-viola.jpeg", alt: "Risotto viola con cipolla rossa" },
    { img: "/immagini/piatti/piatto-06.jpeg", alt: "Risotto alla zucca" },
    { img: "/immagini/piatti/piatto-07.jpeg", alt: "Risotto verde alle erbe" },
  ],
};

const dolci = {
  nome: "Desserts",
  nomeEn: "Daily selection",
  testo: "Una selezione di dolci che cambia ogni giorno in base a cosa prepara la cucina.",
  foto: [
    { img: "/immagini/piatti/dolce.jpg", alt: "Dolce della casa" },
    { img: "/immagini/piatti/dolce-2.jpg", alt: "Dessert della casa con crumble" },
    { img: "/immagini/piatti/piatto-17.jpeg", alt: "Dessert cremoso con crumble" },
  ],
};
---

<Layout
  title="Menu — Osteria del Vicario"
  description="Menu à la carte dell'Osteria del Vicario, Certaldo Alto: piatti, ingredienti e allergeni."
>
  <NavFunnel />

  <PageHeader
    image="/immagini/piatti/risotto-pesto.jpg"
    eyebrow="Menu à la carte"
    title="Il nostro menu"
    text="Ad ogni commensale è richiesto di selezionare un minimo di 2 portate. Per ogni piatto trovi ingredienti e allergeni indicativi."
  />

  <main>
    <section class="pricing">
      <div class="pricing-card">
        <span class="pricing-n">2</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 40</span>
      </div>
      <div class="pricing-card">
        <span class="pricing-n">3</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 50</span>
      </div>
      <div class="pricing-card">
        <span class="pricing-n">4</span>
        <span class="pricing-label">portate</span>
        <span class="pricing-price">€ 65</span>
      </div>
    </section>

    <p class="placeholder-note">
      * Allergeni indicativi in attesa di conferma definitiva dalla cucina. Per allergie e
      intolleranze specifiche, segnalacelo al momento della prenotazione.
    </p>

    <section class="menu-sezione">
      <div class="piatti-grid">
        {piatti.map((p) => (
          <article class="piatto-card tilt-card glass">
            <div class="piatto-img">
              <img src={p.img} alt={p.nome} loading="lazy" width="400" height="300" />
            </div>
            <div class="piatto-body">
              <h3>{p.nome}</h3>
              <p class="nome-en">{p.nomeEn}</p>
              <div class="piatto-meta">
                <div class="meta-block">
                  <span class="meta-label">Ingredienti</span>
                  <p>{p.ingredienti.join(", ")}</p>
                </div>
                <div class="meta-block">
                  <span class="meta-label">Allergeni</span>
                  <p>{p.allergeni.length > 0 ? p.allergeni.join(", ") : "Nessuno dichiarato"}</p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="menu-sezione">
      <h2>{risottoDelMese.nome}</h2>
      <p class="sezione-sub">{risottoDelMese.nomeEn}</p>
      <div class="variant-gallery">
        {risottoDelMese.varianti.map((v) => (
          <div class="variant-item tilt-card">
            <img src={v.img} alt={v.alt} loading="lazy" width="300" height="220" />
          </div>
        ))}
      </div>
      <div class="piatto-meta risotto-meta">
        <div class="meta-block">
          <span class="meta-label">Ingredienti</span>
          <p>{risottoDelMese.ingredienti.join(", ")}</p>
        </div>
        <div class="meta-block">
          <span class="meta-label">Allergeni</span>
          <p>{risottoDelMese.allergeni.join(", ")}</p>
        </div>
      </div>
    </section>

    <section class="menu-sezione">
      <h2>{dolci.nome}</h2>
      <p class="sezione-sub">{dolci.nomeEn}</p>
      <p class="dolci-testo">{dolci.testo}</p>
      <div class="variant-gallery">
        {dolci.foto.map((d) => (
          <div class="variant-item tilt-card">
            <img src={d.img} alt={d.alt} loading="lazy" width="300" height="220" />
          </div>
        ))}
      </div>
    </section>

    <div class="menu-cta">
      <a class="btn btn-cotto" href="/tavolo">Prenota un tavolo</a>
    </div>
  </main>

  <Footer />

  <script>
    import { initTilt } from "../scripts/scroll.js";
    initTilt();
  </script>
</Layout>

<style>
  main {
    background: var(--notte);
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem clamp(1.5rem, 6vw, 6rem) 6rem;
  }

  .pricing {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 1.2rem 1.8rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(232, 177, 90, 0.25);
    background: rgba(242, 233, 215, 0.04);
  }

  .pricing-n {
    font-family: var(--font-display);
    color: var(--oro-sera);
    font-size: 1.6rem;
  }

  .pricing-label {
    color: var(--avorio);
    opacity: 0.7;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-price {
    color: var(--candela);
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-top: 0.3rem;
  }

  .placeholder-note {
    color: var(--ardesia);
    font-size: 0.8rem;
    margin-bottom: 3rem;
    max-width: 700px;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .menu-sezione {
    margin-bottom: 4rem;
  }

  .menu-sezione h2 {
    font-family: var(--font-display);
    color: var(--oro-sera);
    font-size: 1.4rem;
    margin: 0 0 0.3rem;
    text-align: center;
  }

  .sezione-sub {
    color: var(--avorio);
    opacity: 0.6;
    font-style: italic;
    font-size: 0.9rem;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .dolci-testo {
    color: var(--avorio);
    opacity: 0.8;
    text-align: center;
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  .piatti-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .piatto-card {
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    overflow: hidden;
  }

  .piatto-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .piatto-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .piatto-body {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .piatto-body h3 {
    color: var(--avorio);
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin: 0;
  }

  .nome-en {
    color: var(--avorio);
    opacity: 0.55;
    font-style: italic;
    font-size: 0.85rem;
    margin: 0;
  }

  .piatto-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid rgba(242, 233, 215, 0.1);
    padding-top: 0.8rem;
    margin-top: 0.4rem;
  }

  .risotto-meta {
    max-width: 600px;
    margin: 1.5rem auto 0;
  }

  .meta-label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
    color: var(--oliva);
    margin-bottom: 0.2rem;
  }

  .meta-block p {
    color: var(--avorio);
    opacity: 0.75;
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.5;
  }

  .variant-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .variant-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 0.6rem;
    border: 1px solid rgba(242, 233, 215, 0.08);
  }

  .variant-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .menu-cta {
    text-align: center;
    margin-top: 1rem;
  }

  @media (max-width: 760px) {
    .piatti-grid {
      grid-template-columns: 1fr;
    }
    .variant-gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
