---
import Layout from "../layouts/Layout.astro";
import NavFunnel from "../components/NavFunnel.astro";
import FloatingEmblem from "../components/FloatingEmblem.astro";
import MagiaCertaldo from "../components/MagiaCertaldo.astro";
import DormiNellaStoria from "../components/DormiNellaStoria.astro";
import AssaporaToscana from "../components/AssaporaToscana.astro";
import Esperienze from "../components/Esperienze.astro";
import PiattiPreview from "../components/PiattiPreview.astro";
import Terrazza from "../components/Terrazza.astro";
import GalleriaMix from "../components/GalleriaMix.astro";
import Recensioni from "../components/Recensioni.astro";
import FAQ from "../components/FAQ.astro";
import Contatti from "../components/Contatti.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Osteria del Vicario — Certaldo Alto">
  <NavFunnel />

  <main>
    <section class="hero">
      <img
        class="hero-img"
        src="/immagini/luogo/terrazza-vista.jpg"
        alt="Loggia in pietra dell'Osteria del Vicario affacciata sulle colline toscane"
      />
      <div class="hero-overlay"></div>
      <div class="hero-caption">
        <p class="eyebrow">Certaldo Alto, dal 1100</p>
        <h1>Vivi il cuore medievale della Toscana</h1>
        <p class="hero-text">
          Dormi in un monastero del 1100, cammina tra le mura del borgo, cena con la cucina
          vegetale d'autore dell'Osteria del Vicario.
        </p>
        <div class="hero-actions">
          <a class="btn btn-outline" href="/camere">Prenota Camera</a>
          <a class="btn btn-cotto" href="/tavolo">Prenota Tavolo</a>
        </div>
      </div>
      <FloatingEmblem />
    </section>

    <MagiaCertaldo />
    <DormiNellaStoria />
    <AssaporaToscana />
    <Esperienze />
    <PiattiPreview />
    <Terrazza />
    <GalleriaMix />
    <Recensioni />
    <FAQ />
    <Contatti />
  </main>

  <Footer />

  <script>
    import { initScroll, initHero, initEmblem, initTilt } from "../scripts/scroll.js";
    initHero();
    initScroll();
    initEmblem();
    initTilt();
  </script>
</Layout>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform, filter;
    transform-style: preserve-3d;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(33, 23, 16, 0.35) 0%,
      rgba(33, 23, 16, 0.55) 60%,
      rgba(33, 23, 16, 0.9) 100%
    );
  }

  .hero-caption {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
    padding: 2rem;
  }

  .hero-caption h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    color: var(--avorio);
    margin: 0.6rem 0 1.2rem;
  }

  .hero-text {
    color: var(--avorio);
    opacity: 0.9;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
