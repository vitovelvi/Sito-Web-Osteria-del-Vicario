---
import Layout from "../layouts/Layout.astro";
import NavFunnel from "../components/NavFunnel.astro";
import Scene from "../components/Scene.astro";
import FloatingEmblem from "../components/FloatingEmblem.astro";

const journey = [
  {
    image: "/immagini/hero/vicolo-insegna.jpg",
    alt: "Vicolo di pietra di Certaldo Alto con l'insegna dell'Osteria del Vicario",
    eyebrow: "Certaldo Alto",
    title: "Un vicolo, una soglia",
    text: "Tra le pietre del borgo medievale, un passaggio stretto conduce a un monastero che dal 1100 custodisce la sua tavola.",
  },
  {
    image: "/immagini/hero/portone.jpg",
    alt: "Portone antico in mattoni e ferro dell'Osteria del Vicario",
    eyebrow: "Il varco",
    title: "Oltre la soglia",
    text: "Il portone si apre su un tempo diverso: quello lento dell'ospitalità monastica, riscoperto in chiave contemporanea.",
  },
  {
    image: "/immagini/luogo/chiostro-cortile.jpeg",
    alt: "Cortile interno con archi in pietra illuminato la sera",
    eyebrow: "Il chiostro",
    title: "Silenzio e pietra",
    text: "Gli archi del cortile interno raccontano nove secoli di storia. Oggi accolgono chi cerca una sosta autentica.",
  },
  {
    image: "/immagini/luogo/terrazza-vista.jpg",
    alt: "Terrazza panoramica sulla Val d'Elsa",
    eyebrow: "La terrazza",
    title: "La Val d'Elsa ai tuoi piedi",
    text: "Dalla terrazza lo sguardo corre sui colli toscani, mentre la cucina prepara la prima portata della sera.",
  },
  {
    image: "/immagini/piatti/risotto-pesto.jpg",
    alt: "Risotto carnaroli al pesto con chips e crema, piatto vegetale d'autore",
    eyebrow: "La cucina",
    title: "Cucina vegetale d'autore",
    text: "Verdure, legumi ed erbe del territorio diventano piatti che reinterpretano la tradizione toscana senza compromessi.",
    cta: { label: "Prenota un tavolo", href: "/tavolo" },
  },
  {
    image: "/immagini/camere/camera-02.jpg",
    alt: "Camera del B&B con arredi essenziali e luce naturale",
    eyebrow: "Le camere",
    title: "Dormire nel monastero",
    text: "Le celle di un tempo sono oggi camere essenziali e luminose, pensate per chi vuole restare oltre la cena.",
    cta: { label: "Prenota una camera", href: "/camere" },
  },
];
---

<Layout title="Osteria del Vicario — Certaldo Alto">
  <NavFunnel />

  <main>
    {journey.map((scene, i) => (
      <div class="scene-wrap">
        <Scene
          image={scene.image}
          alt={scene.alt}
          eyebrow={scene.eyebrow}
          title={scene.title}
          text={scene.text}
          cta={scene.cta}
        />
        {i === 0 && <FloatingEmblem />}
      </div>
    ))}

    <footer class="closing">
      <p class="eyebrow">Osteria del Vicario</p>
      <h2>Vi aspettiamo oltre la soglia</h2>
      <div class="closing-actions">
        <a class="btn btn-outline" href="/camere">Prenota una camera</a>
        <a class="btn btn-cotto" href="/tavolo">Prenota un tavolo</a>
      </div>
      <p class="closing-address">Via del Castello, Certaldo Alto (FI)</p>
    </footer>
  </main>

  <script>
    import { initScroll, initEmblem } from "../scripts/scroll.js";
    initScroll();
    initEmblem();
  </script>
</Layout>

<style>
  .scene-wrap {
    position: relative;
  }

  .closing {
    position: relative;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    padding: 4rem 1.5rem;
    background: radial-gradient(
        circle at 50% 0%,
        rgba(232, 177, 90, 0.12),
        transparent 60%
      ),
      var(--notte);
  }

  .closing h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--avorio);
  }

  .closing-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .closing-address {
    margin-top: 2rem;
    color: var(--ardesia);
    font-size: 0.9rem;
  }
</style>
